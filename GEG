def get_pdf_bytes():
    buffer = io.BytesIO()
    doc = SimpleDocTemplate(buffer, pagesize=letter, rightMargin=40, leftMargin=40, topMargin=40, bottomMargin=40)
    styles = getSampleStyleSheet()
    title_style = ParagraphStyle('T', parent=styles['Heading1'], fontSize=16, textColor=colors.HexColor("#1A365D"))
    story = [Paragraph("Planungsbericht: GEG-Nachweis & KfW-Check", title_style), Spacer(1, 15)]
    
    # Vereinfachte Tabelle für den PDF Export im Buffer
    data = [
        ["Nachweis-Punkt", "Dein Wert", "Ziel / Status"],
        ["Hüllflächenwert (H_T')", f"{H_T_strich:.3f} W/m²K", "≤ 0.220 (EH40)"],
        ["Primärenergiebedarf", f"{q_p_spez_final:.1f} kWh/m²a", "≤ 25.0 (EH40)"],
        ["CO2-Last (Lebenszyklus)", f"{co2_pro_qm_jahr:.2f} kg/m²a", "QNG-Konform" if co2_pro_qm_jahr<=22 else "Optimieren"],
        ["Maximales Kreditvolumen", f"{gesamtkredit:,.0f} €", f"KfW 300: {kfw_300_status}"],
        ["Reiner Zinsvorteil (10 J.)", f"{ersparnis_10_jahre:,.0f} €", "Geldwerter Vorteil"]
    ]
    t = Table(data, colWidths=)
